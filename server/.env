PORT=4000
CRM_API_BASE_URL=https://apiv2.offersmeta.in

# static-bearer | oauth2-client | forward-client
CRM_AUTH_MODE=static-bearer
CRM_BEARER_TOKEN=

# Optional OAuth2 support
OAUTH_TOKEN_URL=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_SCOPE=

# Optional default query value to scope requests
CRM_PARTNERS_ID=

# CORS
FRONTEND_ORIGIN=http://localhost:5173
