{
  "installCommand": "npm install --prefix project",
  "buildCommand": "npm run build --prefix project",
  "outputDirectory": "project/dist",
  "rewrites": [
    {
      "source": "/api/proxy/(.*)",
      "destination": "/api/proxy/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
